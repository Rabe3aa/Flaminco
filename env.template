# Database (Neon PostgreSQL) - https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth - Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Production URL (required for NextAuth cookies on custom domain)
AUTH_URL="https://flaminco.agency"

# Vercel Blob Storage - Get from Vercel dashboard → Storage → Blob
# Required for image uploads to work in production
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# GoDaddy SMTP (Email sending) - your GoDaddy mailbox credentials
# SMTP_USER = your full email address, e.g. info@flaminco.agency
# SMTP_PASS = your GoDaddy email password for that mailbox
SMTP_USER="info@flaminco.agency"
SMTP_PASS="your-godaddy-email-password"

# Admin credentials (used by seed script only - not needed in production)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-strong-password"
